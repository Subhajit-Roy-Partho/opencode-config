    "nano-gpt": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NanoGPT",
      "options": {
        "baseURL": "{file:~/.config/opencode/local/nanogpt-base-url}",
        "apiKey": "{file:~/.config/opencode/local/nanogpt-api-key}",
        "timeout": 900000,
        "chunkTimeout": 120000,
        "setCacheKey": true
      },
      "models": {
        "zai-org/glm-5": {
          "id": "zai-org/glm-5",
          "name": "GLM 5",
          "family": "zhipu",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "cost": {
            "input": 0.3,
            "output": 2.55
          },
          "limit": {
            "context": 200000,
            "output": 128000
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "zai-org/glm-5:thinking": {
          "id": "zai-org/glm-5:thinking",
          "name": "GLM 5 Thinking",
