{
  "$schema": "https://opencode.ai/config.json",

  // Large-repo defaults favor durable context and lower local overhead.
  "enabled_providers": ["nano-gpt", "local-vpn"],
  "model": "nano-gpt/zai-org/glm-5:thinking",
  "small_model": "nano-gpt/google/gemini-3-flash-preview",
  "default_agent": "build",
  "share": "manual",
  "autoupdate": "notify",
  "snapshot": false,
  "logLevel": "INFO",

  "experimental": {
    "batch_tool": true,
    "mcp_timeout": 20000
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 24000
  },

  "watcher": {
    "ignore": [
      ".git/**",
      ".cache/**",
      ".next/**",
      ".turbo/**",
      ".venv/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      "__pycache__/**",
      "node_modules/**",
      "vendor/**",
      "coverage/**",
      "dist/**",
      "build/**",
      "out/**",
      "target/**",
      "DerivedData/**",
      "Pods/**"
    ]
  },

  "instructions": [
    "./instructions/core.md",
    "./instructions/large-projects.md",
    "AGENTS.md",
    "CLAUDE.md",
    ".cursor/rules/*.md",
    ".cursor/rules/*.mdc"
  ],

  "provider": {
    "local-vpn": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local VPN OpenAI Route",
      "options": {
        "baseURL": "{file:~/.config/opencode/local/local-vpn-base-url}",
        "apiKey": "{file:~/.config/opencode/local/local-vpn-api-key}",
        "timeout": 900000,
        "chunkTimeout": 120000,
        "setCacheKey": true
      },
      "models": {
