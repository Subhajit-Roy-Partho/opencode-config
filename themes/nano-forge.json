{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "basalt": "#111827",
    "midnight": "#0B1220",
    "panel_dark": "#182233",
    "panel_edge": "#243247",
    "mist": "#E8EEF5",
    "muted_dark": "#91A0B5",
    "cyan": "#66D9EF",
    "teal": "#2DD4BF",
    "amber": "#FFB454",
    "rose": "#FF7A90",
    "lime": "#A3E635",
    "blue": "#60A5FA",
    "slate_light": "#F8FAFC",
    "paper": "#EEF2F7",
    "ink": "#0F172A",
    "steel": "#52637A",
    "soft_border": "#CBD5E1",
    "soft_panel": "#E2E8F0"
  },
  "theme": {
    "primary": { "dark": "cyan", "light": "blue" },
    "secondary": { "dark": "amber", "light": "amber" },
    "accent": { "dark": "teal", "light": "teal" },
    "error": { "dark": "rose", "light": "rose" },
    "warning": { "dark": "amber", "light": "amber" },
    "success": { "dark": "lime", "light": "lime" },
    "info": { "dark": "blue", "light": "blue" },
    "text": { "dark": "mist", "light": "ink" },
    "textMuted": { "dark": "muted_dark", "light": "steel" },
    "background": { "dark": "midnight", "light": "slate_light" },
    "backgroundPanel": { "dark": "basalt", "light": "paper" },
    "backgroundElement": { "dark": "panel_dark", "light": "soft_panel" },
    "border": { "dark": "panel_edge", "light": "soft_border" },
    "borderActive": { "dark": "cyan", "light": "blue" },
    "borderSubtle": { "dark": "panel_dark", "light": "paper" },
    "diffAdded": { "dark": "lime", "light": "lime" },
    "diffRemoved": { "dark": "rose", "light": "rose" },
    "diffContext": { "dark": "muted_dark", "light": "steel" },
    "diffHunkHeader": { "dark": "cyan", "light": "blue" },
    "diffHighlightAdded": { "dark": "teal", "light": "teal" },
    "diffHighlightRemoved": { "dark": "rose", "light": "rose" },
    "diffAddedBg": { "dark": "#0F2C22", "light": "#DCFCE7" },
    "diffRemovedBg": { "dark": "#341922", "light": "#FFE4E6" },
    "diffContextBg": { "dark": "#111827", "light": "#F8FAFC" },
    "diffLineNumber": { "dark": "muted_dark", "light": "steel" },
    "diffAddedLineNumberBg": { "dark": "#123527", "light": "#D1FAE5" },
    "diffRemovedLineNumberBg": { "dark": "#3B1620", "light": "#FFE4E6" },
    "markdownText": { "dark": "mist", "light": "ink" },
    "markdownHeading": { "dark": "cyan", "light": "blue" },
    "markdownLink": { "dark": "teal", "light": "teal" },
    "markdownLinkText": { "dark": "mist", "light": "ink" },
    "markdownCode": { "dark": "amber", "light": "amber" },
    "markdownBlockQuote": { "dark": "muted_dark", "light": "steel" },
    "markdownEmph": { "dark": "teal", "light": "teal" },
    "markdownStrong": { "dark": "mist", "light": "ink" },
    "markdownHorizontalRule": { "dark": "panel_edge", "light": "soft_border" },
    "markdownListItem": { "dark": "teal", "light": "teal" },
    "markdownListEnumeration": { "dark": "amber", "light": "amber" },
    "markdownImage": { "dark": "cyan", "light": "blue" },
    "markdownImageText": { "dark": "mist", "light": "ink" },
    "markdownCodeBlock": { "dark": "mist", "light": "ink" },
    "syntaxComment": { "dark": "muted_dark", "light": "steel" },
    "syntaxKeyword": { "dark": "cyan", "light": "blue" },
    "syntaxFunction": { "dark": "teal", "light": "teal" },
    "syntaxVariable": { "dark": "mist", "light": "ink" },
    "syntaxString": { "dark": "lime", "light": "lime" },
    "syntaxNumber": { "dark": "amber", "light": "amber" },
    "syntaxType": { "dark": "blue", "light": "blue" },
    "syntaxOperator": { "dark": "cyan", "light": "blue" },
    "syntaxPunctuation": { "dark": "mist", "light": "ink" }
  }
}
