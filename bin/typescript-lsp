#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOCAL_BIN="$ROOT_DIR/node_modules/.bin/typescript-language-server"

if [[ -x "$LOCAL_BIN" ]]; then
  exec "$LOCAL_BIN" "$@"
fi

if command -v typescript-language-server >/dev/null 2>&1; then
  exec typescript-language-server "$@"
fi

echo "typescript-language-server is not installed. Run $ROOT_DIR/install.sh" >&2
exit 1
